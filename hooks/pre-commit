#!/bin/sh
# Pre-commit hook: lint staged files
# Relies on mise for tool versions

echo "Running pre-commit checks..."

# Frontend: Biome check on staged files
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/src/' | grep -E '\.(ts|tsx|js|jsx)$')
if [ -n "$FRONTEND_FILES" ]; then
    echo "Checking frontend files..."
    cd frontend && mise exec -- bunx biome check --no-errors-on-unmatched $FRONTEND_FILES
    if [ $? -ne 0 ]; then
        echo "Frontend lint failed. Run 'mise run fix:frontend' to auto-fix."
        exit 1
    fi
    cd ..
fi

# Backend: cargo fmt check on staged Rust files
BACKEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^backend/src/' | grep '\.rs$')
if [ -n "$BACKEND_FILES" ]; then
    echo "Checking backend formatting..."
    cd backend && mise exec -- cargo fmt --check
    if [ $? -ne 0 ]; then
        echo "Backend format check failed. Run 'mise run format:backend' to fix."
        exit 1
    fi
    cd ..
fi

echo "Pre-commit checks passed!"
