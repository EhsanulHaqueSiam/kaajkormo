# KaajKormo Production Environment
# Copy to .env and fill in real values before deploying

# ─── Database ──────────────────────────────────────────────────────
DB_USER=kaajkormo
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_NAME=kaajkormo

# ─── Clerk Auth ────────────────────────────────────────────────────
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ─── Search (Meilisearch) ─────────────────────────────────────────
MEILISEARCH_KEY=CHANGE_ME_TO_A_STRONG_KEY

# ─── Ports ─────────────────────────────────────────────────────────
FRONTEND_PORT=80

# ─── Logging ───────────────────────────────────────────────────────
RUST_LOG=info
